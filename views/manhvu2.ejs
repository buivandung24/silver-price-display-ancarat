<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Bảng Giá Bạc LED Ngang - Mạnh Vũ 2</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      margin: 0;
      padding: 0;
      background-color: #ffffff;
      color: #000;
      font-family: Arial, Helvetica, sans-serif;
      height: 100vh;
      width: 100vw;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .container {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    /* Title cố định chiều cao, font vừa 1 dòng */
    .title {
      height: 13vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9vh;
      text-align: center;
      background: linear-gradient(to right, #ff0000, #d26a02, #b3b300, #00cf00, #4444fc, #8000dc, #8b00ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-weight: bold;
      white-space: nowrap;
      overflow: hidden;
      flex-shrink: 0;
    }

    /* Bảng giá chiếm toàn bộ phần còn lại */
    .price-column {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    /* Header cố định */
    .column-header {
      display: grid;
      grid-template-columns: 4fr 1.2fr 1.1fr 1.1fr;
      background-color: #9c2373;
      font-weight: bold;
      font-size: 8vh;
      padding: 1vh 1vw;
      text-align: center;
      color: white;
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* Các hàng giãn đều lấp đầy chiều cao còn lại */
    .rows-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .product-row {
      flex: 1;                   /* Mỗi hàng chiếm phần bằng nhau */
      display: grid;
      grid-template-columns: 4fr 1.2fr 1.1fr 1.1fr;
      background-color: #fffeeb;
      border-bottom: 2px solid #ddd;
      align-items: center;
      padding: 0 1vw;
      color: #000000;
      min-height: 0;
    }

    .product-row:nth-child(even) {
      background-color: #fff8dc;
    }

    .product-name {
      text-align: left;
      font-size: 8vh;
      font-weight: bold;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      padding-right: 1vw;
    }

    .price-val {
      text-align: right;
      font-weight: bold;
      font-size: 9vh;
    }

    .change-val {
      text-align: center;
      font-weight: bold;
      font-size: 8.5vh;
    }

    .change-val.up   { color: #139113; }
    .change-val.down { color: #b61414; }
  </style>
</head>
<body>
  <div class="container">
    <div class="title">MẠNH VŨ SILVER - 91 TRẦN HƯNG ĐẠO - KÍNH CHÀO QUÝ KHÁCH</div>

    <%
      const colSize = Math.ceil(products.length / 1);
      const colProducts = products.slice(0, colSize);
    %>
    <div class="price-column">
      <div class="column-header">
        <div style="text-align:left; padding-left:0.5vw;">Sản phẩm</div>
        <div>Mua</div>
        <div>Bán</div>
        <div>% thay đổi</div>
      </div>

      <div class="rows-wrapper">
        <% colProducts.forEach(product => { %>
          <div class="product-row">
            <div class="product-name"><%= product.name %></div>
            <div class="price-val" style="color:#b61414;"><%= product.buy %></div>
            <div class="price-val" style="color:#139113;"><%= product.sell %></div>
            <div class="change-val <%= product.change > 0 ? 'up' : (product.change < 0 ? 'down' : '') %>">
              <%= product.change !== '-' && product.change != null
                  ? (product.change > 0 ? '+' : '') + product.change + '%'
                  : '-' %>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </div>

  <script>
    async function updatePrices() {
      try {
        const response = await fetch('/api/data');
        if (response.ok) location.reload();
      } catch (err) { console.error('Lỗi:', err); }
    }
    setInterval(updatePrices, 180000);
  </script>
</body>
</html>
