<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Bảng Giá Bạc LED Ngang - Mạnh Vũ 2</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 100vw;
      height: 100vh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      background-color: #ffffff;
      font-family: Arial, Helvetica, sans-serif;
    }

    .container {
      width: 100vw !important;
      height: 100vh !important;
      padding: 0 !important;
      margin: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      overflow: hidden !important;
    }

    /* Title: ~12vh cao, font vừa 1 dòng */
    .title {
      height: 22vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 19.5vh;
      text-align: center;
      background: linear-gradient(to right, #ff0000, #d26a02, #b3b300, #00cf00, #4444fc, #8000dc, #8b00ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-weight: bold;
      white-space: nowrap;
      overflow: hidden;
      flex-shrink: 0;
      line-height: 1;
    }

    .price-column {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    /* 
      Grid: 4fr 1.2fr 1.1fr 1.1fr
      Cột tên SP rộng nhất: "Ngân Long - Bắc Sư Tử 999 - 1 lượng" (35 ký tự)
      Tính toán: font 17vh ≈ 81.6px → 35 ký tự * 0.58 * 81.6 ≈ 1656px < 1695px ✅
    */
    .column-header {
      display: grid;
      grid-template-columns: 4fr 1.2fr 1.1fr 1.1fr;
      background-color: #9c2373;
      font-weight: bold;
      font-size: 14vh;
      padding: 0.5vh 1vw;
      text-align: center;
      color: white;
      white-space: nowrap;
      flex-shrink: 0;
      align-items: center;
    }

    .rows-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .product-row {
      flex: 1;
      display: grid;
      grid-template-columns: 4fr 1.2fr 1.1fr 1.1fr;
      background-color: #fffeeb;
      border-bottom: 2px solid #ddd;
      align-items: center;
      padding: 0 1vw;
      color: #000;
      min-height: 0;
    }

    .product-row:nth-child(even) {
      background-color: #fff8dc;
    }

    /* Font giới hạn bởi chiều ngang: 17vh (~82px) vừa khít tên dài nhất */
    .product-name {
      text-align: left;
      font-size: 17vh;
      font-weight: bold;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      padding-right: 1vw;
      line-height: 1;
    }

    /* Giá và % ngắn hơn → to hơn tý */
    .price-val {
      text-align: right;
      font-weight: bold;
      font-size: 19vh;
      line-height: 1;
    }

    .change-val {
      text-align: center;
      font-weight: bold;
      font-size: 17vh;
      line-height: 1;
    }

    .change-val.up   { color: #139113; }
    .change-val.down { color: #b61414; }
  </style>
</head>
<body>
  <div class="container">
    <div class="title">MẠNH VŨ SILVER - 91 TRẦN HƯNG ĐẠO - KÍNH CHÀO QUÝ KHÁCH</div>

    <div class="price-column">
      <div class="column-header">
        <div style="text-align:left; padding-left:0.5vw;">Sản phẩm</div>
        <div>Mua</div>
        <div>Bán</div>
        <div>% thay đổi</div>
      </div>

      <div class="rows-wrapper">
        <% products.forEach(product => { %>
          <div class="product-row">
            <div class="product-name"><%= product.name %></div>
            <div class="price-val" style="color:#b61414;"><%= product.buy %></div>
            <div class="price-val" style="color:#139113;"><%= product.sell %></div>
            <div class="change-val <%= product.change > 0 ? 'up' : (product.change < 0 ? 'down' : '') %>">
              <%= product.change !== '-' && product.change != null
                  ? (product.change > 0 ? '+' : '') + product.change + '%'
                  : '-' %>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </div>

  <script>
    async function updatePrices() {
      try {
        const response = await fetch('/api/data');
        if (response.ok) location.reload();
      } catch (err) { console.error('Lỗi:', err); }
    }
    setInterval(updatePrices, 180000);
  </script>
</body>
</html>
